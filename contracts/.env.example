# Cüzdan private key (MetaMask → Hesap Ayrıntıları → Private Key'i Göster)
# UYARI: Bu dosyayı asla GitHub'a yükleme, .gitignore'a ekle!
PRIVATE_KEY=your_private_key_here

# Basescan API key (hem mainnet hem sepolia için aynı key kullanılır)
# Ücretsiz almak için: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here
